generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Research {
  projectId String   @map("project_id")
  itemId    String   @map("item_id")
  pack      String // Stored as JSON string
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@id([projectId, itemId])
  @@map("research")
}

model Draft {
  projectId String   @map("project_id")
  itemId    String   @map("item_id")
  meta      String // Stored as JSON string
  markdown  String
  version   Int
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@id([projectId, itemId])
  @@map("drafts")
}

model ArticleTheme {
  id        String   @id @default(uuid())
  name      String // 테마 이름 (예: "깔끔한 블루")
  config    String // JSON: 각 요소별 CSS 설정값
  isDefault Boolean  @default(false) @map("is_default")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("article_themes")
}

model Persona {
  id              String           @id @default(uuid())
  name            String
  systemPrompt    String
  toneDescription String
  negativePrompt  String?

  autopilotQueues AutopilotQueue[]
  categoryCampaigns CategoryCampaign[]

  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @default(now()) @updatedAt @map("updated_at")

  @@map("persona")
}

model AutopilotQueue {
  id           String   @id @default(uuid())
  keyword      String
  status       String   @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED, EXPIRED, WAITING_APPROVAL
  resultUrl    String?
  errorMessage String?
  
  campaignId   String?
  campaign     CategoryCampaign? @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  personaId    String?
  themeId      String? // Phase 7: 디자인 테마 ID
  persona      Persona?  @relation(fields: [personaId], references: [id])

  userId       String?
  user         User?     @relation(fields: [userId], references: [id])

  // Phase 3: 키워드별 개별 설정 (Article Settings)
  articleType  String?   @default("single") // 단일, 비교, 큐레이션
  textModel    String?   @default("gpt-4o")
  imageModel   String?   @default("dall-e-3")
  charLimit    Int?      @default(5000)

  // Phase 3: 쿠팡 아이템 소싱 기준 (Sourcing Criteria)
  sortCriteria String?   @default("salePriceAsc") // 정렬: 랭킹, 가격순 등
  minPrice     Int?      // 최소 가격 필터
  maxPrice     Int?      // 최대 가격 필터
  isRocketOnly Boolean?  @default(false)          // 로켓배송 전용 필터

  // Phase 3: 세밀한 스케줄링 간격 제어 (Scheduling & Interval Control)
  intervalHours Int?     // 작동 주기 (예: 6 = 6시간마다)
  publishTimes  String?  // 특정 발행 시간 배열 (예: "09:00,15:00")
  publishDays   String?  // 특정 요일 배열 (예: "1,2,3,4,5" - 월~금)
  jitterMinutes Int?     @default(15) // 어뷰징 방지 난수화 범위 (기본 15분)
  dailyCap      Int?     // 일일 최대 발행량 제한
  activeTimeStart Int?   // 동작 허용 시작 시간 (예: 9 = 09:00)
  activeTimeEnd   Int?   // 동작 허용 종료 시간 (예: 22 = 22:00)
  nextRunAt       DateTime? @map("next_run_at") // 연산된 다음 실행 예정 시간

  // Phase 4: 반복 횟수 제한 및 종료일 설정
  maxRuns        Int?      // 최대 발행 횟수 (null → 무제한)
  currentRuns    Int       @default(0) // 현재까지 실행된 횟수
  titleRegenRule String?   @default("reuse") // 재생성 규칙 (reuse | generate)
  expiresAt      DateTime? @map("expires_at") // 발행 종료 일시

  // Phase 8: 다중 플랫폼 발행 목적지 (JSON String)
  // 예: [{"platform": "wordpress", "enabled": true, "meta": {"categoryId": "12"}}]
  publishTargets String?
  trafficKeyword       String?
  coupangSearchTerm    String?
  recommendedItemCount Int?
  searchIntent         String?

  // 추가 타겟팅 설정
  targetAge      String?
  targetGender   String?
  targetPrice    String?
  targetIndustry String?

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("autopilot_queue")
}

model CategoryCampaign {
  id             String   @id @default(uuid())
  categoryName   String   // 카테고리 (예: 전자기기, 건강식품 등)
  
  personaId      String?
  persona        Persona? @relation(fields: [personaId], references: [id])
  themeId        String?  // 테마 연결
  
  userId         String?
  user           User?    @relation(fields: [userId], references: [id])
  
  intervalHours  Int      @default(24) // 발행 주기 (시간)
  publishTimes   String?  // 특정 발행 시간 배열 (예: "09:00,15:00")
  publishDays    String?  // 특정 요일 배열 (예: "1,2,3,4,5")
  jitterMinutes  Int?     @default(15) // 어뷰징 방지 난수화 범위 (분)
  dailyCap       Int?     // 일일 최대 발행 권장량
  activeTimeStart Int?
  activeTimeEnd   Int?
  
  batchSize      Int      @default(15) // 한 번에 생성할 키워드 수
  isAutoApprove  Boolean  @default(false) @map("is_auto_approve") // 자동 승인 여부 (추후 확장)

  // 다중 플랫폼 발행 대상 (JSON String)
  publishTargets String?

  // 추가 타겟팅 설정
  targetAge      String?
  targetGender   String?
  targetPrice    String?
  targetIndustry String?

  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at")

  queues         AutopilotQueue[]

  @@map("category_campaign")
}

model User {
  id               String   @id @default(uuid())
  email            String   @unique
  password         String
  nickname         String
  role             String   @default("FREE") // FREE, PRO, ADMIN
  
  // API Integration (SaaS용 개별 API 키 저장)
  coupangAccessKey      String?  @map("coupang_access_key")
  coupangSecretKey      String?  @map("coupang_secret_key")
  openAiApiKey          String?  @map("openai_api_key")
  geminiApiKey          String?  @map("gemini_api_key")
  perplexityApiKey      String?  @map("perplexity_api_key")
  wordpressUrl          String?  @map("wordpress_url")
  wordpressUsername     String?  @map("wordpress_username")
  wordpressAppPassword  String?  @map("wordpress_app_password")

  autopilotQueues AutopilotQueue[]
  categoryCampaigns CategoryCampaign[]
  cartItems        KeywordCartItem[]

  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("users")
}

model KeywordCartItem {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  keyword          String
  
  // 메타데이터 (옵셔널)
  monthlySearchVol Int?     @map("monthly_search_vol")
  competition      String?
  intent           String?

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at")

  @@unique([userId, keyword]) // 한 유저가 같은 키워드를 중복으로 담지 못하도록 복합 유니크 키 설정
  @@map("keyword_cart_items")
}

