generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Research {
  projectId String   @map("project_id")
  itemId    String   @map("item_id")
  pack      String // Stored as JSON string
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@id([projectId, itemId])
  @@map("research")
}

model Draft {
  projectId String   @map("project_id")
  itemId    String   @map("item_id")
  meta      String // Stored as JSON string
  markdown  String
  version   Int
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@id([projectId, itemId])
  @@map("drafts")
}

model ArticleTheme {
  id        String   @id @default(uuid())
  name      String // 테마 이름 (예: "깔끔한 블루")
  config    String // JSON: 각 요소별 CSS 설정값
  isDefault Boolean  @default(false) @map("is_default")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("article_themes")
}

model AutopilotQueue {
  id           String   @id @default(uuid())
  keyword      String
  status       String   @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  resultUrl    String?
  errorMessage String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("autopilot_queue")
}
