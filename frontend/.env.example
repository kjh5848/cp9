# ============================================================
# CP9 환경변수 설정 파일
# 이 파일을 복사하여 .env.local로 생성 후 실제 값을 입력하세요.
# cp .env.example .env.local
# ============================================================

# ===================
# 환경 구분
# ===================
NODE_ENV=development  # development | production
NEXT_PUBLIC_ENV=local  # local | staging | production

# ===================
# 데이터베이스 (Prisma)
# ===================
DATABASE_URL="file:./dev.db"

# ===================
# Supabase 설정
# ===================
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ===================
# 쿠팡 파트너스 API
# ===================
COUPANG_ACCESS_KEY=your_coupang_access_key
COUPANG_SECRET_KEY=your_coupang_secret_key

# ===================
# AI API 키
# ===================
OPENAI_API_KEY=your_openai_api_key
PERPLEXITY_API_KEY=your_perplexity_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
GOOGLE_API_KEY=your_google_api_key

CLAUDE_MODEL=claude-sonnet-4-6

# ===================
# Google OAuth (추후 설정)
# ===================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ===================
# WordPress (추후 설정)
# ===================
WORDPRESS_API_KEY=your_wordpress_api_key
WORDPRESS_SITE_URL=your_wordpress_site_url

# ===================
# Base URL
# ===================
# 로컬: http://localhost:3000
# 프로덕션: https://your-domain.com
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ===================
# Langfuse 모니터링 (선택사항)
# ===================
# https://cloud.langfuse.com 에서 무료 계정 생성 후 키 발급
LANGFUSE_SECRET_KEY=your_langfuse_secret_key
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com

# ===================
# NextAuth 설정
# ===================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET="your-secret-key-here"