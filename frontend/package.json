{
  "name": "cp9-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev",
    "dev:doppler": "doppler run -- next dev",
    "dev:cron": "node scripts/local-cron.js",
    "build": "prisma generate && NODE_ENV=production next build",
    "build:doppler": "NODE_ENV=production doppler run -- next build",
    "start": "NODE_ENV=production next start",
    "start:doppler": "NODE_ENV=production doppler run -- next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@langchain/anthropic": "^1.3.20",
    "@langchain/core": "^1.1.27",
    "@langchain/google-genai": "^2.1.20",
    "@langchain/openai": "^1.2.9",
    "@prisma/client": "^6.19.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-switch": "^1.2.6",
    "@supabase/supabase-js": "^2.38.4",
    "@tailwindcss/typography": "^0.5.19",
    "@types/marked": "^5.0.2",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "duck-duck-scrape": "^2.2.7",
    "framer-motion": "^12.35.1",
    "langfuse": "^3.38.6",
    "langfuse-langchain": "^3.38.6",
    "lucide-react": "^0.539.0",
    "marked": "^17.0.3",
    "moment": "^2.30.1",
    "next": "^15.3.9",
    "next-auth": "^4.24.13",
    "nuqs": "^2.8.9",
    "react": "19.0.0",
    "react-big-calendar": "^1.19.4",
    "react-dom": "19.0.0",
    "react-hook-form": "^7.48.2",
    "react-hot-toast": "^2.5.2",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.3.1",
    "zod-to-json-schema": "^3.25.1",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.1",
    "@tailwindcss/postcss": "^4.1.11",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "19.0.8",
    "@types/react-big-calendar": "^1.16.3",
    "@typescript-eslint/eslint-plugin": "^8.39.1",
    "@typescript-eslint/parser": "^8.39.1",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^9.33.0",
    "eslint-config-next": "15.1.7",
    "postcss": "^8",
    "prisma": "^6.4.1",
    "tailwindcss": "^4",
    "typescript": "^5.9.2",
    "vitest": "^1.0.4"
  }
}
